{
  "name": "digital-product-store-backend",
  "version": "1.0.0",
  "description": "Backend API for Premium Digital Product Store",
  "main": "dist/server.js",
  "scripts": {
    "start": "npx prisma db push --accept-data-loss && node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "prisma generate && tsc",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^11.10.1",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "razorpay": "^2.9.2",
    "redis": "^4.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.5",
    "nodemon": "^3.0.1",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
