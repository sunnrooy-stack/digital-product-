generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  firebaseUid   String    @unique
  email         String    @unique
  name          String
  avatar        String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      Product[] // Products sold by this user (if SELLER)
  orders        Order[]   // Orders placed by this user
  reviews       Review[]
  wishlist      Wishlist[]
  supportTickets SupportTicket[]
  earnings      Earning[]
}

model Product {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  price         Float
  category      String
  tags          String[]
  coverImage    String
  previewMedia  String[]  // Array of image/video URLs
  fileUrls      String[]  // The actual digital products (ZIP, PDF, etc)
  status        ProductStatus @default(PENDING_APPROVAL)
  isPublished   Boolean   @default(false)
  isFeatured    Boolean   @default(true)
  metaTitle     String?
  metaDescription String?
  publishDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sellerId String @db.ObjectId
  seller        User      @relation(fields: [sellerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  categoryId String? @db.ObjectId
  categoryRef   Category? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  orders        OrderItem[]
  reviews       Review[]
  wishlistedBy  Wishlist[]
}

model Category {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String     @unique
  parentId String? @db.ObjectId
  parent          Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subCategories   Category[] @relation("SubCategories")
  metaTitle       String?
  metaDescription String?
  products        Product[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Order {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber   String    @unique
  totalAmount   Float
  status        OrderStatus @default(PENDING)
  paymentId     String?   // Razorpay payment ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  items         OrderItem[]
  refundRequest RefundRequest?
}

model OrderItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  priceAtPurchase Float

  orderId String @db.ObjectId
  order         Order     @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  productId String @db.ObjectId
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Review {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  rating        Int
  comment       String?
  createdAt     DateTime  @default(now())

  userId String @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  productId String @db.ObjectId
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Wishlist {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime  @default(now())

  userId String @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  productId String @db.ObjectId
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, productId])
}

model Coupon {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  code          String    @unique
  discountPct   Float     // Percentage discount
  validUntil    DateTime
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model RefundRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  reason        String
  status        ProductStatus @default(PENDING_APPROVAL) // Reusing status enum for simplicity: PENDING, APPROVED, REJECTED
  createdAt     DateTime  @default(now())

  orderId String @unique @db.ObjectId
  order         Order     @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SupportTicket {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  subject       String
  message       String
  status        String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Earning {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  amount        Float
  createdAt     DateTime  @default(now())

  sellerId String @db.ObjectId
  seller        User      @relation(fields: [sellerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
